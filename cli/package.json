{
  "name": "@dero-hive/cli",
  "version": "0.1.0",
  "description": "Terminal / CLI interface for DERO Hive",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "hive": "./bin/hive.js"
  },
  "scripts": {
    "build": "node ../scripts/build-cli.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p ../tsconfig.cli.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "tsx src/tui/commands.test.ts && tsx src/services/conversation.test.ts && tsx src/services/permissions.test.ts && tsx src/tui/render.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^14.1.3",
    "marked-terminal": "^7.1.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.2"
  }
}

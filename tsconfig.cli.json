{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./cli/dist",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "cli/src/**/*.ts",
    "cli/src/**/*.tsx",
    "src/main/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": ["node_modules", "cli/dist", "out", "src/main/index.ts", "src/main/media/**/*", "src/main/ipc/media.ts"]
}

{
  "name": "dero-hive",
  "version": "0.1.0",
  "description": "DERO Hive - a feature-rich AI harness supporting OpenAI-compatible providers, MCP, and tools",
  "main": "out/main/index.js",
  "author": "DERO",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "cli"
  ],
  "bin": {
    "hive": "cli/bin/hive.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "postinstall": "node scripts/patch-codex-acp.mjs && node scripts/patch-sqlite3-dual.mjs && node scripts/setup-whisper.mjs && node scripts/setup-mcp.mjs && node scripts/setup-simulator.mjs",
    "rebuild": "node scripts/patch-sqlite3-dual.mjs",
    "rebuild:electron": "node scripts/patch-sqlite3-dual.mjs",
    "setup:cli": "node scripts/patch-sqlite3-dual.mjs",
    "setup:whisper": "node scripts/setup-whisper.mjs",
    "setup:mcp": "node scripts/setup-mcp.mjs",
    "setup:simulator": "node scripts/setup-simulator.mjs",
    "build": "electron-vite build && node scripts/build-cli.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:win": "npm run build && electron-builder --win --x64",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:cli",
    "typecheck:cli": "tsc --noEmit -p tsconfig.cli.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:cli": "eslint \"cli/src/**/*.{ts,tsx}\"",
    "test:vision": "tsx src/renderer/src/lib/visionViewer.test.ts",
    "test:cli": "tsx cli/src/tui/commands.test.ts && tsx cli/src/services/conversation.test.ts && tsx cli/src/services/permissions.test.ts && tsx cli/src/tui/render.test.ts",
    "cli": "node cli/bin/hive.js",
    "cli:dev": "tsx cli/src/index.ts",
    "hive": "node cli/bin/hive.js",
    "cli:link": "npm link --workspace @dero-hive/cli"
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "^1.1.2",
    "@agentclientprotocol/sdk": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.3.0",
    "electron-store": "^10.0.0",
    "eventsource-parser": "^3.0.0",
    "fast-glob": "^3.3.2",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.17.0",
    "marked": "^14.1.3",
    "mermaid": "^11.16.0",
    "pyodide": "^0.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^1.22.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.21.5",
    "eslint": "^10.6.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.dero.hive",
    "productName": "DERO Hive",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "cli/bin/**/*",
      "cli/dist/**/*",
      "cli/package.json",
      "!resources/whisper/**",
      "!resources/simulator/**",
      "!resources/mcp/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/simulator",
        "to": "simulator",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/mcp",
        "to": "mcp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/shiki/**",
      "**/node_modules/@agentclientprotocol/codex-acp/**",
      "**/node_modules/@openai/codex/**",
      "**/node_modules/@openai/codex-win32-x64/**",
      "**/node_modules/@openai/codex-win32-arm64/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false,
      "signtoolOptions": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "electron@32.3.3": true,
    "esbuild@0.21.5": true
  }
}
